  "info": {
    "_postman_id": "4ccb4b96-0266-43c4-9dd8-3f674925f08b",
    "name": "MySQL REST Service (MRS) Runtime API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The MySQL REST Service exposes a runtime HTTP API for authenticating\nagainst MRS-managed services and OAuth2 vendors. This specification\ndocuments the fixed authentication endpoints. Dynamic data endpoints\nare generated at runtime per database schema and object, and are not\nenumerated here.\n",
      "type": "text/plain"
    }
